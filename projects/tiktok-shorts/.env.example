# --- 必須: 台本・トレンド調査 ---
ANTHROPIC_API_KEY=sk-ant-...
# 使うモデル（任意。既定 claude-sonnet-4-6）
SHORTS_MODEL=claude-sonnet-4-6

# --- 公式API投稿: 1アカウント連携 (TikTok for Developers) ---
# アプリを作成し Content Posting API を追加、下記3つを設定する。
# スコープ: 下書き=video.upload / 自動公開=video.publish
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
# 連携は `shorts auth url` → ブラウザ承認 → `shorts auth login "<リダイレクトURL>"`。
# 取得したトークンは .tiktok_tokens.json に保存され、失効時は自動更新される。
#
# （任意）固定トークンを手動で使いたい場合だけ。設定すると上の連携より優先される:
# TIKTOK_ACCESS_TOKEN=

# --- 任意: TTSを別プロバイダにしたいとき（既定は無料の edge-tts でキー不要） ---
# ELEVENLABS_API_KEY=
# OPENAI_API_KEY=
