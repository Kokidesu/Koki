# --- 必須: 台本・トレンド調査 ---
ANTHROPIC_API_KEY=sk-ant-...
# 使うモデル（任意。既定 claude-sonnet-4-6）
SHORTS_MODEL=claude-sonnet-4-6

# --- 公式API投稿 (TikTok for Developers の OAuth で取得) ---
# 下書きアップロードには video.upload、自動公開には video.publish スコープが必要
TIKTOK_ACCESS_TOKEN=

# --- 任意: TTSを別プロバイダにしたいとき（既定は無料の edge-tts でキー不要） ---
# ELEVENLABS_API_KEY=
# OPENAI_API_KEY=
